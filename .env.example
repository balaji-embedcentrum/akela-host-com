# akela-host.com — web-app config contract
# Copy to .env. This configures the WEB APP, not the rented agents.
# Defaults below run the full stack locally with ZERO external accounts.

# ── App ───────────────────────────────────────────────────────────────────
APP_ENV=dev                       # dev | prod
APP_BASE_URL=http://localhost:8000
FRONTEND_BASE_URL=http://localhost:5173
AGENTS_DOMAIN=agents.akela-host.com   # Traefik routes {slot}/(a2a|ws) under this
JWT_SECRET=dev-only-change-me
SESSION_COOKIE_SECURE=false       # true in prod (HTTPS only)

# ── Web-app database (Postgres) ───────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://akela:akela@localhost:5432/akela_host

# ── Provider mode switches (mock => no external account needed) ───────────
# Flip one to "real" only when you have that service's credentials (post-MVP).
FLEET_MODE=mock                   # mock=local Postgres schema | real=Supabase
BILLING_MODE=mock                 # mock=fake Stripe         | real=Stripe
PROVISIONER_MODE=mock             # mock=local Docker        | real=SSH/VPS
AUTH_MODE=mock                    # mock=fixed identity      | real=Supabase Auth
EMAIL_MODE=mock                   # mock=console/file sink   | real=Resend/SMTP

# ── Fleet registry (real mode only: Supabase) ─────────────────────────────
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Mock mode uses this schema inside DATABASE_URL's Postgres:
FLEET_SCHEMA=fleet
FLEET_SEED_SLOTS=10               # slots created by `make seed` in mock mode

# ── Billing (real mode only: Stripe) ──────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=                  # the $4/mo recurring price
AGENT_MONTHLY_PRICE_CENTS=400

# ── Auth (real mode only: Supabase Auth / OAuth) ──────────────────────────
SUPABASE_ANON_KEY=
OAUTH_GITHUB_CLIENT_ID=
OAUTH_GITHUB_CLIENT_SECRET=
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=
MOCK_OAUTH_EMAIL=dev@akela-host.test   # identity returned by MockOAuth

# ── Provisioner ───────────────────────────────────────────────────────────
# mock: local Docker daemon. real: SSH to the agent host.
HERMES_ADAPTER_IMAGE=hermes-adapter:latest   # built from local hermes-adapter repo
SLOTS_HOST_ROOT=/opt/akela-host/slots        # per-slot {.env,workspaces,data}
# real (SSH) mode only:
SSH_HOST=
SSH_PORT=22
SSH_USER=root
# SSH private key resolved from the fleet registry (encrypted) — never put it here.

# ── Email (real mode only) ────────────────────────────────────────────────
RESEND_API_KEY=
EMAIL_FROM=no-reply@akela-host.com
EMAIL_SINK_PATH=.dev/email-sink.jsonl    # mock mode writes here (tests assert on it)

# ── Agent runtime defaults (injected into each slot container) ────────────
# These are NON-secret. The user's own secret .env is uploaded separately and is
# NEVER stored here or in any DB (see docs/DECISIONS.md D12).
AGENT_WORKSPACE_DIR=/workspaces
AGENT_HERMES_HOME=/opt/data
AGENT_A2A_PORT=9000               # do NOT change to 9001 (see D5)
AGENT_WORKSPACE_PORT=8766
